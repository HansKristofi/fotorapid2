---
import Layout from '../layouts/Layout.astro';
import FadeInUp from '../components/FadeInUp.jsx';
import ServiceGallery from '../components/ServiceGallery.jsx';
import OpeningHours from '../components/OpeningHours.jsx';
import FloatingActionButton from '../components/FloatingActionButton.jsx';
import PhotographyBackground from '../components/PhotographyBackground.jsx';
import ReviewsTicker from '../components/ReviewsTicker.jsx';
---

<Layout title="Foto Rapid Oradea – Fotografii de calitate în timp record" description="Foto Rapid Oradea – developăm fotografii de calitate în timp record din 2008. Poze buletin, nunți, evenimente, poze printate. Calea Republicii nr. 21, Oradea.">
  
  <!-- Hero Section -->
  <section id="hero" class="relative min-h-[90vh] flex items-center justify-center pt-20 pb-16">
    <!-- Animated Photography Background (Deferred) -->
    <PhotographyBackground client:idle />

    <div class="relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col lg:flex-row items-center justify-between gap-12">
      <!-- Text Content -->
      <div class="flex-1 text-center lg:text-left">
        <FadeInUp client:load delay={0.1}>
          <h1 class="text-4xl md:text-6xl font-extrabold text-white tracking-tight mb-6 drop-shadow-lg">
            Fotografii de calitate în <span class="text-primary">timp record.</span>
          </h1>
        </FadeInUp>
        <FadeInUp client:load delay={0.2}>
          <p class="text-lg md:text-xl text-stone-300 mb-8 max-w-2xl mx-auto lg:mx-0 drop-shadow-md">
            Amplasare centrală, prețuri accesibile, atenție la detalii și rapiditate – asta ne definește din 2008.
          </p>
        </FadeInUp>
        <FadeInUp client:load delay={0.3}>
          <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4">
            <a href="#contact" class="px-8 py-4 bg-primary hover:bg-primary-hover text-white font-bold rounded-full transition-colors shadow-lg shadow-orange-500/30">
              Contactează-ne
            </a>
            <a href="#galerie" class="px-8 py-4 bg-white/10 hover:bg-white/20 backdrop-blur-md text-white font-bold rounded-full transition-colors border border-white/10">
              Vezi Servicii
            </a>
          </div>
        </FadeInUp>
      </div>

      <!-- Opening Hours Component (Deferred) -->
      <div class="flex-1 w-full flex justify-center lg:justify-end">
        <OpeningHours client:idle />
      </div>
    </div>
  </section>

  <!-- Despre noi -->
  <section id="despre" class="py-20 bg-dark-card border-y border-white/5 relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <FadeInUp client:visible>
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Despre noi</h2>
          <div class="w-24 h-1 bg-primary mx-auto rounded-full"></div>
        </div>
      </FadeInUp>
      
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <FadeInUp client:visible delay={0.1}>
          <div class="space-y-6 text-stone-300 text-lg leading-relaxed">
            <p>
              <strong class="text-white">Foto Rapid Oradea</strong> s-a înființat în <strong class="text-white">1989</strong>. Oferim fotografii de calitate, rapid și la prețuri corecte. De atunci, am ajutat mii de orădeni — de la studenți care aveau nevoie de o poză de buletin, până la perechi care și-au dorit amintiri perfecte de la nuntă.
            </p>
            <p>
              Ne mândrim cu <strong class="text-white">amplasarea centrală</strong> (Calea Republicii nr. 21), cu echipamentele moderne și cu zâmbetul cu care vă primim la ușă. Fie că ai nevoie de o poză urgentă sau de un album de familie, suntem aici pentru tine.
            </p>
          </div>
        </FadeInUp>
        
        <FadeInUp client:visible delay={0.2}>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
            <div class="glass-panel p-6 text-center border-t-4 border-t-primary">
              <span class="block text-4xl font-extrabold text-white mb-2">37+</span>
              <span class="text-sm font-medium text-primary">Ani de experiență</span>
            </div>
            <div class="glass-panel p-6 text-center border-t-4 border-t-primary">
              <span class="block text-4xl font-extrabold text-white mb-2">5000+</span>
              <span class="text-sm font-medium text-primary">Clienți mulțumiți</span>
            </div>
            <div class="glass-panel p-6 text-center border-t-4 border-t-primary">
              <span class="block text-4xl font-extrabold text-white mb-2">15 min</span>
              <span class="text-sm font-medium text-primary">Timp de livrare</span>
            </div>
          </div>
        </FadeInUp>
      </div>
    </div>
  </section>

  <!-- Galerie Servicii -->
  <section id="galerie" class="py-24 relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <FadeInUp client:visible>
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Serviciile Noastre</h2>
          <div class="w-24 h-1 bg-primary mx-auto rounded-full mb-6"></div>
          <p class="text-stone-400 max-w-2xl mx-auto">De la fotografii tip buletin la pachete complete pentru evenimente. Alege calitatea și rapiditatea.</p>
        </div>
      </FadeInUp>
      
      <ServiceGallery client:visible />
    </div>
  </section>

  <!-- Recenzii -->
  <section id="recenzii" class="py-24 bg-dark-card border-y border-white/5 relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <FadeInUp client:visible>
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Ce spun clienții noștri</h2>
          <div class="w-24 h-1 bg-primary mx-auto rounded-full mb-6"></div>
          
          <div class="inline-flex items-center justify-center gap-3 bg-white/5 backdrop-blur-sm border border-white/10 px-6 py-3 rounded-full mt-4">
            <div class="flex text-yellow-500 gap-1 text-lg">
              <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
            </div>
            <span class="text-stone-300 font-medium whitespace-nowrap">5 / 5 pe Google</span>
          </div>
        </div>
      </FadeInUp>
      
      <div class="-mx-4 sm:mx-0">
        <ReviewsTicker client:visible />
      </div>
    </div>
  </section>

  <!-- Locatie & Contact -->
  <section class="py-20 relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        
        <!-- Locatie -->
        <div id="locatie">
          <FadeInUp client:visible>
            <h2 class="text-3xl font-bold text-white mb-4">Unde ne găsești</h2>
            <div class="w-16 h-1 bg-primary rounded-full mb-6"></div>
            <p class="text-lg text-stone-300 mb-8 flex items-center gap-3">
              <i class="fas fa-map-marker-alt text-primary text-xl px-2"></i> 
              Calea Republicii nr. 21, Oradea
            </p>
            
            <div class="rounded-2xl overflow-hidden shadow-2xl glass-panel p-2 h-[400px]">
              <iframe 
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2731.994!2d21.930!3d47.065!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4747b0b0b0b0b0b0%3A0x0!2sCalea%20Republicii%2021%2C%20Oradea%20410032!5e0!3m2!1sro!2sro!4v1730000000000!5m2!1sro!2sro"
                width="100%" 
                height="100%" 
                style="border:0; border-radius: 0.75rem;" 
                allowfullscreen="" 
                loading="lazy">
              </iframe>
            </div>
          </FadeInUp>
        </div>

        <!-- Contact -->
        <div id="contact" class="flex flex-col justify-center">
          <FadeInUp client:visible delay={0.2}>
            <div class="glass-panel p-10 relative overflow-hidden">
              <div class="absolute -right-16 -bottom-16 w-64 h-64 bg-green-500/10 rounded-full blur-3xl"></div>
              
              <h2 class="text-3xl font-bold text-white mb-4">Contactează-ne rapid</h2>
              <div class="w-16 h-1 bg-green-500 rounded-full mb-8"></div>
              
              <p class="text-stone-300 mb-10">Ai întrebări sau vrei să programezi o ședință? Scrie-ne pe WhatsApp sau sună-ne. Îți răspundem imediat!</p>
              
              <div class="flex flex-col gap-6">
                <a href="https://wa.me/40771013142?text=Bună!%20Vreau%20să%20dezvolt%20niște%20poze..." target="_blank" class="flex items-center gap-4 bg-green-600 hover:bg-green-500 text-white p-5 rounded-2xl transition-all shadow-[0_0_20px_rgba(22,163,74,0.3)] hover:shadow-[0_0_30px_rgba(22,163,74,0.5)] group">
                  <i class="fab fa-whatsapp text-4xl group-hover:scale-110 transition-transform"></i>
                  <div class="text-left">
                    <span class="block font-bold text-lg">Scrie-ne pe WhatsApp</span>
                    <span class="text-sm text-green-100">Răspuns Rapid</span>
                  </div>
                </a>

                <a href="tel:+40771013142" class="flex items-center gap-4 bg-white/5 hover:bg-white/10 border border-white/10 text-white p-5 rounded-2xl transition-all group">
                  <div class="w-12 h-12 flex items-center justify-center bg-stone-800 rounded-xl group-hover:bg-primary transition-colors">
                    <i class="fas fa-phone-alt text-xl text-stone-300 group-hover:text-white"></i>
                  </div>
                  <div class="text-left">
                    <span class="block text-sm text-stone-400">Sau sună direct la:</span>
                    <span class="block font-bold text-xl tracking-wide">0771 013 142</span>
                  </div>
                </a>
              </div>
            </div>
          </FadeInUp>
        </div>
      </div>
    </div>
  </section>

  <!-- Mobile Floating Action Button (Deferred) -->
  <FloatingActionButton client:idle />
</Layout>
